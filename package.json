{
  "name": "codingkitty",
  "version": "0.1.0",
  "private": true,
  "description": "CodingKitty — Stray cat care platform monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "dev": "npm run dev --workspace @codingkitty/server",
    "dev:client": "npm run start --workspace @codingkitty/client"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "ajv": "^8.20.0",
    "eslint": "^10.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "@expo/ngrok": {
      "uuid": "^11.1.1"
    },
    "xcode": {
      "uuid": "^11.1.1"
    },
    "uuid": "^11.1.1",
    "zod": "4.4.0"
  }
}
