// CodingKitty Prisma Schema
// PostgreSQL with PostGIS (spatial) and pgvector (embeddings) extensions

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, vector]
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  displayName   String
  passwordHash  String
  xp            Int      @default(0)
  createdAt     DateTime @default(now())

  // Relations
  discoveries     UserCatDiscovery[]
  ownerships      Ownership[]
  sightings       Sighting[]
  donations       Donation[]
  medicalRequests MedicalRequest[]
  chatMessages    ChatMessage[]
  inventory       UserInventory[]
  discoveredCats     Cat[]              @relation("FirstDiscoverer")
  refreshTokens      RefreshToken[]
  donationXpLogs     DonationXpLog[]
  scanXpLogs         ScanXpLog[]
  notificationLogs   NotificationLog[]
  rewardGrants       LevelRewardGrant[]
  coupons            Coupon[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Cat {
  id                  String                      @id @default(uuid())
  name                String?
  embeddingRef        String                      @default("")
  firstDiscovererId   String
  lastKnownApproxLat  Float                       @default(0)
  lastKnownApproxLng  Float                       @default(0)
  photoUrl            String?
  registeredAt        DateTime                    @default(now())

  // Relations
  firstDiscoverer User              @relation("FirstDiscoverer", fields: [firstDiscovererId], references: [id])
  discoveries     UserCatDiscovery[]
  ownerships      Ownership[]
  sightings       Sighting[]
  donations       Donation[]
  medicalRequests MedicalRequest[]
  chatMessages    ChatMessage[]
  donationXpLogs  DonationXpLog[]
  scanXpLogs      ScanXpLog[]
  embeddings      CatEmbedding[]
  rewardGrants    LevelRewardGrant[]

  // Indexes
  @@index([lastKnownApproxLat, lastKnownApproxLng], name: "idx_cat_approx_location")
}

// A gallery of re-ID embeddings per cat, one row per scan. MegaDescriptor
// embeddings are pose/angle-sensitive, so a single reference vector fails to
// match whenever a rescan's pose differs from whatever was stored last;
// matching instead uses each cat's BEST (closest) embedding across the whole
// gallery. See VectorService.
model CatEmbedding {
  id        String                      @id @default(uuid())
  catId     String
  embedding Unsupported("vector(768)")?
  createdAt DateTime                    @default(now())

  cat Cat @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@index([catId])
}

model UserCatDiscovery {
  userId       String
  catId        String
  discoveredAt DateTime @default(now())

  // Relations
  user      User        @relation(fields: [userId], references: [id])
  cat       Cat         @relation(fields: [catId], references: [id])
  ownership Ownership?

  // Compound primary key
  @@id([userId, catId])
}

model Ownership {
  userId String
  catId  String
  level  Int      @default(0)
  xp     Int      @default(0)
  since  DateTime @default(now())

  // Requirement 16 — inactivity & revocation.
  // lastActiveAt: refreshed on every donation or daily scan for this cat.
  // revokedAt: non-null while owner privileges are revoked; level/xp are
  // retained so a re-scan restores the previously attained level (Req 16.4).
  // inactivityWarnedAt: when the 30-days-before-revocation warning was sent;
  // cleared whenever activity resumes.
  lastActiveAt       DateTime  @default(now())
  revokedAt          DateTime?
  inactivityWarnedAt DateTime?

  // Relations
  user      User             @relation(fields: [userId], references: [id])
  cat       Cat              @relation(fields: [catId], references: [id])
  // FK to UserCatDiscovery: enforces Requirement 14.3 — Ownership can only exist
  // if a corresponding UserCatDiscovery record exists for the same (userId, catId).
  discovery UserCatDiscovery @relation(fields: [userId, catId], references: [userId, catId])

  // Compound primary key
  @@id([userId, catId])
}

model Sighting {
  id         String   @id @default(uuid())
  catId      String
  reporterId String
  timestamp  DateTime @default(now())
  fuzzedLat  Float
  fuzzedLng  Float
  photoUrl   String   @default("")
  type       String   @default("scan") // 'scan' | 'manual'

  // Relations
  cat      Cat  @relation(fields: [catId], references: [id])
  reporter User @relation(fields: [reporterId], references: [id])

  // Geo index on fuzzed coordinates
  @@index([fuzzedLat, fuzzedLng], name: "idx_sighting_fuzzed_geo")
}

model Donation {
  id          String   @id @default(uuid())
  donorId     String
  catId       String
  foodItemId  String?
  foodItem    String   @default("")
  amountCents Int
  source      String   @default("wallet") // 'wallet' | 'direct'
  workflowId  String   @default("")
  status      String   @default("pending") // 'pending' | 'escrowed' | 'released' | 'refunded'
  createdAt   DateTime @default(now())

  // Relations
  donor        User      @relation(fields: [donorId], references: [id])
  cat          Cat       @relation(fields: [catId], references: [id])
  foodItemRef  FoodItem? @relation(fields: [foodItemId], references: [id])
}

model MedicalRequest {
  id          String   @id @default(uuid())
  catId       String
  requesterId String
  type        String   @default("medical") // 'medical' | 'grooming'
  // Requirement 9.4: requester must explain why care is needed.
  reason      String   @default("")
  // Lifecycle: 'pending' (staff review) | 'awaiting_owner' (owner picks a
  // location) | 'pending_review' (staff arrange with the chosen clinic) |
  // 'in_progress' (service window, 30 days) | 'reimbursed' | 'rejected' | 'timed_out'
  status      String   @default("pending")
  partnerId   String?
  workflowId  String   @default("")
  documents   String[] @default([])
  // Requirement 9.7: staff-supplied reason shown to the user on rejection.
  rejectionReason String?
  // Requirement 9.9: amount released from the community pool, and when.
  amountCents  Int       @default(0)
  reimbursedAt DateTime?
  // Two-sided completion proof (Req 9.8): the user's receipt (submitted
  // in-app with photos) and the partner's invoice/proof (staff-entered).
  // Verification is signalled once BOTH are present.
  receiptUrl  String?
  invoiceUrl  String?
  createdAt   DateTime @default(now())

  // Relations
  cat       Cat      @relation(fields: [catId], references: [id])
  requester User     @relation(fields: [requesterId], references: [id])
  partner   Partner? @relation(fields: [partnerId], references: [id])
  events    MedicalRequestEvent[]
}

// Stage-transition trail for a MedicalRequest so the owner can trace every
// status change of their request (who/when/why is captured in `note`).
model MedicalRequestEvent {
  id        String   @id @default(uuid())
  requestId String
  status    String
  note      String   @default("")
  createdAt DateTime @default(now())

  request MedicalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}

model ChatMessage {
  id        String   @id @default(uuid())
  catId     String
  senderId  String
  content   String
  // Optional photo attachment (host-less /api/recognition/photos/... path) —
  // used by "share scan photo to chat" (Requirement 4.9).
  photoUrl  String?
  createdAt DateTime @default(now())

  // Relations
  cat    Cat  @relation(fields: [catId], references: [id])
  sender User @relation(fields: [senderId], references: [id])
}

model Partner {
  id           String  @id @default(uuid())
  name         String
  type         String  @default("vet") // 'vet' | 'salon'
  contactEmail String
  verified     Boolean @default(false)
  // Requirement 9.13: partner locations "in the area" shown to the requester.
  address      String  @default("")
  lat          Float?
  lng          Float?

  // Relations
  medicalRequests MedicalRequest[]
}

model FoodItem {
  id          String  @id @default(uuid())
  name        String
  priceCents  Int
  description String?
  imageUrl    String?

  // Relations
  donations Donation[]
  inventory UserInventory[]
}

model UserInventory {
  userId     String
  foodItemId String
  quantity   Int @default(0)

  // Relations
  user     User     @relation(fields: [userId], references: [id])
  foodItem FoodItem @relation(fields: [foodItemId], references: [id])

  // Compound primary key
  @@id([userId, foodItemId])
}

// Requirement 17: level-reward grants. One row per user–cat–level so each
// level's reward is granted exactly once, even if the level is re-evaluated.
model LevelRewardGrant {
  userId     String
  catId      String
  level      Int
  // 'coupon' | 'free_item' | 'keychain_order' | 'none'
  rewardType String
  grantedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  cat  Cat  @relation(fields: [catId], references: [id])

  @@id([userId, catId, level])
}

// Requirement 17.2, 17.8, 17.12: single-use discount coupons with a minimum
// purchase, expiring 30 days after grant.
model Coupon {
  id               String    @id @default(uuid())
  userId           String
  amountOffCents   Int
  minPurchaseCents Int
  grantedForCatId  String?
  grantedAtLevel   Int?
  expiresAt        DateTime
  usedAt           DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model DonationXpLog {
  id        String   @id @default(uuid())
  userId    String
  catId     String
  xpAwarded Int
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
  cat  Cat  @relation(fields: [catId], references: [id])

  // Index for daily cap queries
  @@index([userId, catId, createdAt])
}

// Tracks scan XP awards so re-sighting XP is granted only once per unique
// daily scan per user–cat pair (Requirement 6.2). Mirrors DonationXpLog.
model ScanXpLog {
  id        String   @id @default(uuid())
  userId    String
  catId     String
  xpAwarded Int
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
  cat  Cat  @relation(fields: [catId], references: [id])

  // Index for once-per-day queries
  @@index([userId, catId, createdAt])
}

model NotificationLog {
  id          String   @id @default(uuid())
  userId      String
  title       String
  body        String
  isMilestone Boolean  @default(false)
  sentAt      DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  // Index for rate-limit sliding window queries
  @@index([userId, sentAt])
}
