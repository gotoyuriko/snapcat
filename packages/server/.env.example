# Database connection string
# Ensure PostgreSQL has PostGIS and pgvector extensions installed
# Port 5433 is used to avoid conflict with any local PostgreSQL instance on 5432
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/codingkitty?schema=public"

# JWT secrets
JWT_SECRET="your-jwt-secret-change-me"
JWT_REFRESH_SECRET="your-refresh-secret-change-me"

# AI Services
YOLO_API_URL="https://api.ultralytics.com/v1/predict"
YOLO_API_KEY=""
MEGADESCRIPTOR_API_URL="https://api-inference.huggingface.co/models/wildlife-tools/megadescriptor"
MEGADESCRIPTOR_API_KEY=""

# Payment Gateway (Sandbox)
PAYMENT_GATEWAY_URL=""
PAYMENT_GATEWAY_SECRET=""
PAYMENT_WEBHOOK_SECRET=""

# Object Storage (MinIO local / S3 compatible)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="codingkitty"

# Temporal
TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="default"

# Push Notifications
FCM_SERVER_KEY=""

# Server
PORT=3000
NODE_ENV=development
